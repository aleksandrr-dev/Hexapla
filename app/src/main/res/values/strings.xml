    <string name="topics_gospel">Good News</string>
    <string name="gospel_intro">What must I do to be saved? These verses walk through God\'s plan of salvation, straight from Scripture, step by step. Tap any verse to open it in the Bible.</string>
    <string name="gospel_step1">1 · All have sinned</string>
    <string name="gospel_step2">2 · The penalty for sin</string>
    <string name="gospel_step3">3 · Christ paid it all</string>
    <string name="gospel_step4">4 · A free gift — not by works</string>
    <string name="gospel_step5">5 · Believe on the Lord Jesus Christ</string>
    <string name="gospel_step6">6 · Everlasting means everlasting</string>
    <string name="gospel_step7">7 · Call upon the Lord</string>
